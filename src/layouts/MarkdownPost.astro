---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import { estimateReadingTime, formatDate } from "../utils";
import { SITE_TITLE } from "../consts";

const { frontmatter } = Astro.props;
const rawContent = typeof Astro.props.rawContent === "function" ? await Astro.props.rawContent() : Astro.props.rawContent ?? "";
const type = frontmatter.tags[0];
const { pubDate, title, description, featured } = frontmatter;
const dateFormated = formatDate(pubDate);
const readingTime = estimateReadingTime(rawContent);
const currentPath = Astro.url.pathname.replace(/\/$/, "");

const allPosts = Object.values(import.meta.glob("../pages/posts/*.md", { eager: true }));
allPosts.sort((a, b) => Date.parse(b.frontmatter.pubDate) - Date.parse(a.frontmatter.pubDate));

const currentIndex = allPosts.findIndex((post) => post.url?.replace(/\/$/, "") === currentPath);
const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const olderPost = currentIndex >= 0 && currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;

const relatedPosts = allPosts
  .filter((post) => post.url?.replace(/\/$/, "") !== currentPath)
  .map((post) => {
    const sharedTags = post.frontmatter.tags.filter((tag) => frontmatter.tags.includes(tag));
    return { post, score: sharedTags.length };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score || Date.parse(b.post.frontmatter.pubDate) - Date.parse(a.post.frontmatter.pubDate))
  .slice(0, 3)
  .map((item) => item.post);
---

<html lang="zh-CN" dir="ltr" class="js no-touch progressive-image no-reduced-motion progressive">
  <head>
    <BaseHead title={`${title} - ${SITE_TITLE}`} description={description} image={frontmatter.cover.square} />
  </head>
  <body class:list={["page-article", { "theme-dark": frontmatter.theme === "dark" }]}>
    <Header />
    <main id="main" class="main" data-pagefind-body>
      <section>
        <article class="article">
          <div class:list={[{ "featured-header": featured, "article-header": !featured }]}>
            <div class="category component">
              <div class="component-content">
                <div class="category-eyebrow">
                  <span class="category-eyebrow__category category_original">{type}</span>
                  <span class="category-eyebrow__date">{dateFormated}</span>
                  <span class="category-eyebrow__meta">{readingTime}</span>
                </div>
              </div>
            </div>
            <div class="pagetitle component">
              <div class="component-content">
                <h1 class="hero-headline">{title}</h1>
              </div>
            </div>
            <div class:list={[{ "featured-subhead": featured, "article-subhead": !featured }, "component"]}>
              <div class="component-content">{description}</div>
            </div>

            <div class:list={["tagssheet component"]}>
              <div class="component-content">
                {
                  frontmatter.tags.map((tag) => {
                    return (
                      <a href={`/tags/${tag}`} class="tag">
                        {tag}
                      </a>
                    );
                  })
                }
              </div>
            </div>
          </div>
          <slot />

          <div class="article-discover">
            {(newerPost || olderPost) && (
              <div class="article-discover__card">
                <div class="article-discover__eyebrow">继续阅读</div>
                <div class="article-nav">
                  {newerPost && (
                    <a href={newerPost.url} class="article-nav__item">
                      <span class="article-nav__label">上一篇</span>
                      <span class="article-nav__title">{newerPost.frontmatter.title}</span>
                    </a>
                  )}
                  {olderPost && (
                    <a href={olderPost.url} class="article-nav__item">
                      <span class="article-nav__label">下一篇</span>
                      <span class="article-nav__title">{olderPost.frontmatter.title}</span>
                    </a>
                  )}
                </div>
              </div>
            )}

            {relatedPosts.length > 0 && (
              <div class="article-discover__card">
                <div class="article-discover__eyebrow">相关文章</div>
                <div class="article-related">
                  {relatedPosts.map((post) => (
                    <a href={post.url} class="article-related__item">
                      <span class="article-related__tag">{post.frontmatter.tags[0]}</span>
                      <span class="article-related__title">{post.frontmatter.title}</span>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>

          <script
            src="https://utteranc.es/client.js"
            repo="maizee/blog"
            issue-term="pathname"
            theme="github-light"
            crossorigin="anonymous"
            async
          ></script>
        </article>
      </section>
    </main>
    <Footer />
    <script is:inline>
      var script = document.createElement("script");
      script.src = "/static/js/initPost.js";
      document.head.appendChild(script);
    </script>
  </body>
</html>
